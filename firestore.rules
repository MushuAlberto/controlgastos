rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: expenses
    // Document ID: auto-generated
    // Fields:
    //   - amount: number (required, > 0)
    //   - category: string (required, enum)
    //   - description: string (optional, max 200 chars)
    //   - date: string (required, ISO 8601)
    //   - userId: string (required, matches auth.uid)
    //   - createdAt: string (required, ISO 8601)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "cristiantapia.espinoza@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidExpense(data) {
      let requiredFields = ['amount', 'category', 'date', 'userId', 'createdAt'];
      let allowedFields = ['amount', 'category', 'description', 'date', 'userId', 'createdAt'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.amount is number && data.amount > 0 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}.*") &&
             data.userId is string && data.userId == request.auth.uid &&
             data.createdAt is string &&
             (!('description' in data) || (data.description is string && data.description.size() <= 200));
    }

    function isValidGoal(data) {
      let requiredFields = ['title', 'targetAmount', 'currentAmount', 'userId'];
      return data.keys().hasAll(requiredFields) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.targetAmount is number && data.targetAmount > 0 &&
             data.currentAmount is number && data.currentAmount >= 0 &&
             data.userId is string && data.userId == request.auth.uid;
    }

    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidExpense(request.resource.data);
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      isValidExpense(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /goals/{goalId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidGoal(request.resource.data);
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      isValidGoal(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    // Connection test path
    match /test/connection {
      allow read: if true;
    }
  }
}
