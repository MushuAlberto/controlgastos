rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TEMPORARY: Allow anyone to read and write for testing purposes
    // This bypasses the need for authentication while the mobile login is fixed.
    
    match /expenses/{expenseId} {
      allow read, write: if true;
    }
    
    match /goals/{goalId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
